---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import LogCalendar from "@/components/LogCalendar.astro";
import LogList from "@/components/LogList.astro";

const allPosts = await getCollection("blog");

// 将所有文章按年月日分组
type PostItem = { title: string; slug: string; category: string };
type PostsData = Record<string, Record<string, PostItem[]>>;

const postsData: PostsData = {};

for (const post of allPosts) {
  const d = new Date(post.data.pubDate);
  const year = d.getFullYear();
  const month = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  const key = `${year}-${month}`;

  if (!postsData[key]) {
    postsData[key] = {};
  }
  if (!postsData[key][day]) {
    postsData[key][day] = [];
  }
  postsData[key][day].push({
    title: post.data.title,
    slug: post.id,
    category: post.data.category || "",
  });
}
---

<Layout title="日志 — 李树孳孳" description="博客更新日志日历">

  <section class="max-w-3xl mx-auto px-6 py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">日志</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-10">博客文章的更新日历</p>

    <LogCalendar class="mb-12" />
    <LogList />

    <div id="log-empty-state" class="hidden text-center py-20 text-gray-400 dark:text-gray-500">
      暂无更新记录
    </div>
  </section>
</Layout>

<script define:vars={{ postsData }} is:inline>
(() => {
  const calendarBody = document.getElementById("calendar-body");
  const monthTitle = document.getElementById("month-title");
  const logListContent = document.getElementById("log-list-content");
  const logEmptyState = document.getElementById("log-empty-state");
  const logList = document.getElementById("log-list");

  const WEEKDAYS = ["日", "一", "二", "三", "四", "五", "六"];
  const MONTH_NAMES = [
    "一月", "二月", "三月", "四月", "五月", "六月",
    "七月", "八月", "九月", "十月", "十一月", "十二月",
  ];

  // 当前显示的月份
  const now = new Date();
  let currentYear = now.getFullYear();
  let currentMonth = now.getMonth() + 1;

  function getDaysInMonth(year, month) {
    return new Date(year, month, 0).getDate();
  }

  function getFirstDayOfMonth(year, month) {
    return new Date(year, month - 1, 1).getDay();
  }

  function render() {
    const monthKey = `${currentYear}-${String(currentMonth).padStart(2, "0")}`;
    const monthData = postsData[monthKey] || {};
    const daysInMonth = getDaysInMonth(currentYear, currentMonth);
    const firstDay = getFirstDayOfMonth(currentYear, currentMonth);
    const today = new Date();
    const isCurrentMonthReal =
      currentYear === today.getFullYear() && currentMonth === today.getMonth() + 1;

    // 更新标题
    monthTitle.textContent = `${currentYear}年${currentMonth}月`;

    // 渲染日历
    let cells = [];
    // 空白格
    for (let i = 0; i < firstDay; i++) {
      cells.push(null);
    }
    // 日期格
    for (let d = 1; d <= daysInMonth; d++) {
      cells.push(d);
    }

    let html = "";
    const rows = Math.ceil(cells.length / 7);
    for (let r = 0; r < rows; r++) {
      html += '<tr>';
      for (let c = 0; c < 7; c++) {
        const idx = r * 7 + c;
        const day = cells[idx];
        if (day == null) {
          html += '<td></td>';
        } else {
          const dayStr = String(day).padStart(2, "0");
          const hasPosts = !!monthData[dayStr] && monthData[dayStr].length > 0;
          const isToday =
            isCurrentMonthReal && day === today.getDate();

          let classes = "text-center p-2 text-sm rounded-lg transition-colors";

          if (hasPosts) {
            // 有文章：绿色填充
            classes += " bg-primary-500 text-white font-medium";
          } else if (isToday) {
            // 今天无文章：圆环边框
            classes += " text-gray-800 dark:text-gray-200 border-2 border-primary-400 dark:border-primary-500 font-medium";
          } else {
            // 普通日
            classes += " text-gray-700 dark:text-gray-300";
          }

          html += `<td><div class="${classes}">${day}</div></td>`;
        }
      }
      html += "</tr>";
    }
    calendarBody.innerHTML = html;

    // 渲染日志列表
    const days = Object.keys(monthData).sort((a, b) => parseInt(b) - parseInt(a));

    if (days.length === 0) {
      logList.classList.add("hidden");
      logEmptyState.classList.remove("hidden");
      logEmptyState.textContent = `${currentYear}年${currentMonth}月暂无更新`;
    } else {
      logList.classList.remove("hidden");
      logEmptyState.classList.add("hidden");

      let listHtml = "";
      for (const day of days) {
        const posts = monthData[day];
        const dayNum = parseInt(day);
        listHtml += `
          <div class="mb-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400 font-bold text-sm">
                ${dayNum}
              </span>
              <span class="text-sm font-medium text-gray-500 dark:text-gray-400">
                ${currentYear}年${currentMonth}月${dayNum}日
              </span>
            </div>
            <div class="ml-14 space-y-2">
        `;
        for (const post of posts) {
          listHtml += `
            <a
              href="/blog/${post.slug}"
              class="block px-4 py-3 rounded-lg bg-gray-50 dark:bg-gray-800/50 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors border border-gray-200 dark:border-gray-700"
            >
              <div class="flex items-center justify-between">
                <span class="text-sm font-medium text-gray-800 dark:text-gray-200">${post.title}</span>
                ${post.category ? `<span class="text-xs px-2 py-0.5 rounded-full bg-primary-100 dark:bg-primary-900 text-primary-600 dark:text-primary-400">${post.category}</span>` : ""}
              </div>
            </a>
          `;
        }
        listHtml += `
            </div>
          </div>
        `;
      }
      logListContent.innerHTML = listHtml;
    }
  }

  // 绑定导航按钮
  document.getElementById("prev-month").addEventListener("click", () => {
    currentMonth--;
    if (currentMonth === 0) {
      currentMonth = 12;
      currentYear--;
    }
    render();
  });

  document.getElementById("next-month").addEventListener("click", () => {
    currentMonth++;
    if (currentMonth === 13) {
      currentMonth = 1;
      currentYear++;
    }
    render();
  });

  // 初始渲染
  render();
})();
</script>
