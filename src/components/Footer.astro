---
import { SITE_TITLE } from "@/consts";

const today = new Date();
---

<footer
  class="w-full border-t border-gray-200 dark:border-gray-800 py-8 mt-20"
>
  <div
    class="max-w-5xl mx-auto px-6 text-center text-sm text-gray-500 dark:text-gray-400"
  >
    <p>&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.</p>
  </div>
</footer>
